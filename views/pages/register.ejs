
    <!-- Register -->
    <div class="container mt-4 mb-5">

        <div class="row justify-content-center">

            <div class="col-md-6 col-lg-5">

                <div class="auth-card shadow-sm border-0"
                    style="border-radius: 24px; overflow: hidden; background-color: white;">

                    <!-- Header Card -->
                    <div class="auth-header text-center py-4 px-4"
                        style="background: linear-gradient(135deg, #d99152, #c97d45); color: white;">

                        <h2 class="fw-bold mb-2">
                            Criar Conta
                        </h2>

                        <p class="mb-0 opacity-75">
                            Faça parte da comunidade Craft Corner
                        </p>
                    </div>

                    <!-- Conteúdo -->
                    <div class="p-4">

                        <!-- Flash Messages -->
                        <% if (messages.error && messages.error.length > 0) { %>
                            <div class="alert alert-danger border-0 shadow-sm"
                                style="border-radius: 14px;">

                                <%= messages.error %>
                            </div>
                        <% } %>

                        <% if (messages.success && messages.success.length > 0) { %>
                            <div class="alert alert-success border-0 shadow-sm"
                                style="border-radius: 14px;">

                                <%= messages.success %>
                            </div>
                        <% } %>

                        <form action="/register" method="POST">

                            <div class="mb-3">
                                <label for="username" class="form-label fw-semibold">
                                    Nome de Usuário
                                </label>

                                <input
                                    type="text"
                                    class="form-control"
                                    id="username"
                                    name="username"
                                    placeholder="Escolha um nome de usuário"
                                    required
                                    style="border-radius: 12px; padding: 12px;">
                            </div>

                            <div class="mb-3">
                                <label for="fullName" class="form-label fw-semibold">
                                    Nome Completo
                                </label>

                                <input
                                    type="text"
                                    class="form-control"
                                    id="fullName"
                                    name="fullName"
                                    placeholder="Seu nome completo">
                            </div>

                            <div class="mb-3">
                                <label for="email" class="form-label fw-semibold">
                                    E-mail
                                </label>

                                <input
                                    type="email"
                                    class="form-control"
                                    id="email"
                                    name="email"
                                    placeholder="Seu melhor e-mail"
                                    required
                                    style="border-radius: 12px; padding: 12px;">
                            </div>

                            <div class="mb-3">
                                <label for="password" class="form-label fw-semibold">
                                    Senha
                                </label>

                                <input
                                    type="password"
                                    class="form-control"
                                    id="password"
                                    name="password"
                                    placeholder="Crie uma senha segura"
                                    required
                                    minlength="8"
                                    style="border-radius: 12px; padding: 12px;">
                            </div>

                            <div class="mb-4">
                                <label for="confirmPassword" class="form-label fw-semibold">
                                    Confirmar Senha
                                </label>

                                <input
                                    type="password"
                                    class="form-control"
                                    id="confirmPassword"
                                    name="confirmPassword"
                                    placeholder="Confirme sua senha"
                                    required
                                    style="border-radius: 12px; padding: 12px;">
                            </div>

                            <div class="d-grid gap-2 mb-3">

                                <button type="submit"
                                    class="btn btn-lg"
                                    style="background-color: #d99152; color: white; border-radius: 14px;">

                                    Criar Conta
                                </button>

                            </div>

                            <p class="text-center text-muted mb-0">

                                Já tem uma conta?

                                <a href="/login"
                                    class="text-decoration-none fw-semibold"
                                    style="color: #d99152;">

                                    Fazer login
                                </a>
                            </p>

                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
