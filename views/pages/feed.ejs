     <div class="container-fluid px-lg-5">

        <div class="row">

            <!-- Sidebar -->
            <%- include("../partials/sidebar") %>

            <!-- Main Content -->
            <main class="col-12 col-md-9 col-lg-10 py-4">

                <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">

                    <div>
                        <h4 class="fw-bold mb-1" style="color: #5c3d2e;">
                            Feed Global
                        </h4>

                        <p class="text-muted mb-0">
                            Explore projetos criativos da comunidade Craft Corner.
                        </p>
                    </div>

                    <div class="btn-group shadow-sm">

                        <button class="btn btn-sm active border"
                            style="background-color: #d99152; color: white;">
                            Recentes
                        </button>

                        <button class="btn btn-sm border bg-white">
                            Populares
                        </button>

                    </div>
                </div>

                <div class="row g-4">

                    <!-- Card 1 -->
                    <div class="col-6 col-md-4 col-lg-3">

                        <div class="video-card bg-white shadow-sm h-100"
                            style="border-radius: 20px; overflow: hidden;">

                            <div class="thumbnail-placeholder d-flex align-items-center justify-content-center position-relative"
                                style="height: 220px; background-color: #f3e6dc;">

                                <i class="bi bi-brush play-icon fs-1"
                                    style="color: #c07b48;"></i>

                                <span class="badge-views position-absolute top-0 end-0 m-3 px-2 py-1 rounded-pill bg-white shadow-sm small">
                                    <i class="bi bi-eye"></i> 1.2k
                                </span>
                            </div>

                            <div class="p-3">

                                <h6 class="text-truncate mb-1 fw-semibold">
                                    Pintura Floral em Tela
                                </h6>

                                <div class="d-flex align-items-center">
                                    <span class="text-muted small">
                                        @atelier_da_ana
                                    </span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Card 2 -->
                    <div class="col-6 col-md-4 col-lg-3">

                        <div class="video-card bg-white shadow-sm h-100"
                            style="border-radius: 20px; overflow: hidden;">

                            <div class="thumbnail-placeholder d-flex align-items-center justify-content-center position-relative"
                                style="height: 220px; background-color: #efe4d7;">

                                <i class="bi bi-scissors play-icon fs-1"
                                    style="color: #b46e3c;"></i>

                                <span class="badge-views position-absolute top-0 end-0 m-3 px-2 py-1 rounded-pill bg-white shadow-sm small">
                                    <i class="bi bi-eye"></i> 850
                                </span>
                            </div>

                            <div class="p-3">

                                <h6 class="text-truncate mb-1 fw-semibold">
                                    Customização de Jeans
                                </h6>

                                <span class="text-muted small">
                                    @craft_style
                                </span>
                            </div>
                        </div>
                    </div>

                    <!-- Card 3 -->
                    <div class="col-6 col-md-4 col-lg-3">

                        <div class="video-card bg-white shadow-sm h-100"
                            style="border-radius: 20px; overflow: hidden;">

                            <div class="thumbnail-placeholder d-flex align-items-center justify-content-center position-relative"
                                style="height: 220px; background-color: #f8eee7;">

                                <i class="bi bi-flower1 play-icon fs-1"
                                    style="color: #cf8a57;"></i>

                                <span class="badge-views position-absolute top-0 end-0 m-3 px-2 py-1 rounded-pill bg-white shadow-sm small">
                                    <i class="bi bi-eye"></i> 2.5k
                                </span>
                            </div>

                            <div class="p-3">

                                <h6 class="text-truncate mb-1 fw-semibold">
                                    Decoração com Flores
                                </h6>

                                <span class="text-muted small">
                                    @decorando_com_amor
                                </span>
                            </div>
                        </div>
                    </div>

                    <!-- Card 4 -->
                    <div class="col-6 col-md-4 col-lg-3">

                        <div class="video-card bg-white shadow-sm h-100"
                            style="border-radius: 20px; overflow: hidden;">

                            <div class="thumbnail-placeholder d-flex align-items-center justify-content-center position-relative"
                                style="height: 220px; background-color: #f3e9df;">

                                <i class="bi bi-palette play-icon fs-1"
                                    style="color: #bb7443;"></i>

                                <span class="badge-views position-absolute top-0 end-0 m-3 px-2 py-1 rounded-pill bg-white shadow-sm small">
                                    <i class="bi bi-eye"></i> 3.1k
                                </span>
                            </div>

                            <div class="p-3">

                                <h6 class="text-truncate mb-1 fw-semibold">
                                    Arte em Cerâmica
                                </h6>

                                <span class="text-muted small">
                                    @studio_barro
                                </span>
                            </div>
                        </div>
                    </div>

                </div>

                <!-- Botão -->
                <div class="text-center mt-5">

                    <button class="btn px-5 rounded-pill fw-bold"
                        style="border: 2px solid #d99152; color: #d99152;">

                        Carregar mais projetos
                    </button>

                </div>

            </main>
        </div>
    </div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
