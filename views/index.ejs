<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CraftCorner</title>

    <!-- CSS -->
    <link rel="stylesheet" href="/stylesheets/style.css">
</head>

<body>

<div class="container">

    <!-- Cabeçalho -->
    <header class="header">
        <h1 class="logo">🧵 CraftCorner</h1>

        <div class="header-actions">
            <input type="text" placeholder="Buscar tutoriais..." class="search-input" />

            <a href="/register" class="btn btn-dark">
                Criar Conta
            </a>

            <a href="/login" class="btn btn-light">
                Entrar
            </a>
        </div>
    </header>

    <!-- Hero -->
    <section class="hero">
        <h2>Que projeto vamos fazer hoje?</h2>
        <p>
            Explore tutoriais de artesanato e transforme ideias em criações incríveis.
        </p>
    </section>

    <!-- Categorias -->
    <h3 class="section-title">Categorias</h3>

    <div class="categories">
        <div class="category-card">🧶<br>Tricô & Crochê</div>
        <div class="category-card">🎨<br>Pintura</div>
        <div class="category-card">🪡<br>Costura</div>
        <div class="category-card">📦<br>Origami</div>
        <div class="category-card">🪵<br>Madeira</div>
        <div class="category-card">🌸<br>Floricultura</div>
    </div>

    <!-- Tutoriais -->
    <h3 class="section-title">Tutoriais em Destaque</h3>

    <div class="tutorials">

        <!-- Card -->
        <div class="card">
            <div class="card-preview">[Preview]</div>
            <div class="card-content">
                <p><strong>Bolsa de Crochê Básica</strong></p>
                <p class="card-info">🕒 45 min • Iniciante</p>
                <button class="btn-fav">♡ Favoritar</button>
            </div>
        </div>

        <div class="card">
            <div class="card-preview">[Preview]</div>
            <div class="card-content">
                <p><strong>Vaso de Macramê</strong></p>
                <p class="card-info">🕒 90 min • Médio</p>
                <button class="btn-fav">♡ Favoritar</button>
            </div>
        </div>

        <div class="card">
            <div class="card-preview">[Preview]</div>
            <div class="card-content">
                <p><strong>Quadro Decorativo</strong></p>
                <p class="card-info">🕒 60 min • Iniciante</p>
                <button class="btn-fav">♡ Favoritar</button>
            </div>
        </div>

    </div>

    <!-- CTA -->
    <div class="cta">
        <a href="/login" class="cta-button">
            Explorar todos os tutoriais
        </a>
    </div>

</div>

</body>
</html>