<!DOCTYPE html>
<html lang="pt-br">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Criar Conta | Craft Corner</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">

    <!-- CSS -->
    <link rel="stylesheet" href="/stylesheets/style.css">

</head>

<body>

    <!-- Header -->
    <header class="container">
        <div class="header">
            <a href="/" class="logo">
                <i class="bi bi-scissors"></i> Craft Corner
            </a>
        </div>
    </header>

    <main class="container register-wrapper">

        <div class="register-card">

            <!-- Flash Messages -->
            <% if (messages.error && messages.error.length > 0) { %>
                <div class="alert alert-danger">
                    <%= messages.error %>
                </div>
            <% } %>

            <% if (messages.success && messages.success.length > 0) { %>
                <div class="alert alert-success">
                    <%= messages.success %>
                </div>
            <% } %>

            <h1 class="register-title">Criar conta</h1>
            <p class="register-subtitle">
                Faça parte da comunidade Craft Corner
            </p>

            <form action="/register" method="POST">

                <div class="mb-3">
                    <label class="form-label">Nome de usuário</label>

                    <div class="input-group">
                        <span class="input-group-text">
                            <i class="bi bi-at"></i>
                        </span>

                        <input
                            type="text"
                            class="form-control"
                            name="username"
                            placeholder="ex: joaosilva"
                            required>
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label">
                        Nome completo
                        <span class="text-muted">(Opcional)</span>
                    </label>

                    <div class="input-group">
                        <span class="input-group-text">
                            <i class="bi bi-person"></i>
                        </span>

                        <input
                            type="text"
                            class="form-control"
                            name="fullName"
                            placeholder="João Silva">
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label">E-mail</label>

                    <div class="input-group">
                        <span class="input-group-text">
                            <i class="bi bi-envelope"></i>
                        </span>

                        <input
                            type="email"
                            class="form-control"
                            name="email"
                            placeholder="seu@email.com"
                            required>
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label">Senha</label>

                    <div class="input-group">
                        <span class="input-group-text">
                            <i class="bi bi-lock"></i>
                        </span>

                        <input
                            type="password"
                            class="form-control"
                            name="password"
                            placeholder="Mínimo 8 caracteres"
                            required
                            minlength="8">
                    </div>
                </div>

                <div class="mb-4">
                    <label class="form-label">Confirmar senha</label>

                    <div class="input-group">
                        <span class="input-group-text">
                            <i class="bi bi-shield-check"></i>
                        </span>

                        <input
                            type="password"
                            class="form-control"
                            name="confirmPassword"
                            placeholder="Repita sua senha"
                            required>
                    </div>
                </div>

                <button type="submit" class="btn btn-register w-100">
                    Criar Conta
                </button>

                <div class="text-center mt-4">
                    <p class="text-muted">
                        Já possui conta?

                        <a href="/login" class="login-link">
                            Fazer login
                        </a>
                    </p>
                </div>

            </form>
        </div>
    </main>

    <footer class="py-4">
        <div class="container text-center">
            <p class="small text-muted mb-0">
                &copy; 2026 Craft Corner
            </p>
        </div>
    </footer>

</body>

</html>