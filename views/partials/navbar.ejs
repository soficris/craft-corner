<% if (user) { %>
    <!-- Navbar para Usuário Logado -->
    <nav class="navbar navbar-expand-lg navbar-light bg-white sticky-top border-bottom">
        <div class="container-fluid px-lg-5 py-2">
            
            <!-- Logo -->
            <a class="navbar-brand fw-bold d-flex align-items-center gap-2" href="/feed"
                style="font-family: 'Poppins', sans-serif; color: #5c3d2e;">
                <i class="bi bi-palette-fill" style="color: #d99152;"></i>
                <span>Craft Corner</span>
            </a>

            <!-- Campo de Busca -->
            <form class="d-none d-md-flex mx-auto" style="width: 40%;">
                <div class="input-group">
                    <input 
                        type="text" 
                        class="form-control border-0 shadow-sm"
                        placeholder="Pesquisar projetos, ideias ou criadores..."
                        style="border-radius: 20px 0 0 20px; background-color: #f7f3ee;"
                    >
                    <button 
                        class="btn border-0 shadow-sm"
                        type="button"
                        style="border-radius: 0 20px 20px 0; background-color: #f7f3ee;"
                    >
                        <i class="bi bi-search"></i>
                    </button>
                </div>
            </form>

            <div class="d-flex align-items-center">

                <!-- Botão Upload -->
                <a href="/upload"
                    class="btn me-3 d-none d-sm-block px-3 py-2"
                    style="background-color: #d99152; color: white; border-radius: 12px;">
                    <i class="bi bi-plus-circle me-1"></i> Novo Projeto
                </a>

                <!-- Dropdown Usuário -->
                <div class="dropdown">
                    <a href="#"
                        class="d-block link-dark text-decoration-none dropdown-toggle"
                        id="dropdownUser"
                        data-bs-toggle="dropdown"
                        aria-expanded="false">

                        <img 
                            src="<%= user.profilePicture ? 
                                '/uploads/profiles/' + user.profilePicture : 
                                '/images/default-profile.png' %>"
                            alt="<%= user.username %>"
                            width="40"
                            height="40"
                            class="rounded-circle border shadow-sm"
                            style="object-fit: cover;"
                        >
                    </a>

                    <ul class="dropdown-menu dropdown-menu-end text-small shadow border-0 mt-3 rounded-4"
                        aria-labelledby="dropdownUser">

                        <li>
                            <a class="dropdown-item py-2" href="/profile/edit">
                                <i class="bi bi-person me-2"></i> Meu Perfil
                            </a>
                        </li>

                        <li>
                            <a class="dropdown-item py-2" href="/my-videos">
                                <i class="bi bi-grid me-2"></i> Meus Projetos
                            </a>
                        </li>

                        <li>
                            <a class="dropdown-item py-2" href="/settings">
                                <i class="bi bi-gear me-2"></i> Configurações
                            </a>
                        </li>

                        <li>
                            <hr class="dropdown-divider">
                        </li>

                        <li>
                            <a class="dropdown-item py-2 text-danger" href="/logout">
                                <i class="bi bi-box-arrow-right me-2"></i> Sair
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </nav>

<% } else { %>

    <!-- Navbar para Visitante (Não Logado) -->
    <nav class="navbar navbar-expand-lg navbar-light bg-white sticky-top border-bottom">
        <div class="container py-2">

            <!-- Logo -->
            <a class="navbar-brand fw-bold d-flex align-items-center gap-2"
                href="/"
                style="font-family: 'Poppins', sans-serif; color: #5c3d2e;">
                <i class="bi bi-palette-fill" style="color: #d99152;"></i>
                <span>Craft Corner</span>
            </a>

            <button class="navbar-toggler"
                type="button"
                data-bs-toggle="collapse"
                data-bs-target="#navbarNav">

                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">

                <ul class="navbar-nav ms-auto align-items-center gap-2">

                    <li class="nav-item">
                        <a class="btn px-4"
                            href="/login"
                            style="border: 1px solid #d99152; color: #d99152; border-radius: 12px;">
                            Entrar
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="btn px-4"
                            href="/register"
                            style="background-color: #d99152; color: white; border-radius: 12px;">
                            Criar Conta
                        </a>
                    </li>

                </ul>
            </div>
        </div>
    </nav>

<% } %>