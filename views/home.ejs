<!DOCTYPE html>
<html lang="pt-br">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Início | Craft Corner</title>

    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">

    <!-- Custom CSS -->
    <link rel="stylesheet" href="/stylesheets/style.css">
</head>

<body>

    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-light bg-white sticky-top shadow-sm">
        <div class="container-fluid px-lg-5">
            <a class="navbar-brand fw-bold" href="/feed">
                <i class="bi bi-brush-fill"></i> CRAFT CORNER
            </a>

            <!-- Campo de Busca -->
            <form class="d-none d-md-flex mx-auto" style="width: 40%;">
                <div class="input-group">
                    <input type="text" class="form-control bg-light border-0"
                        placeholder="Pesquisar tutoriais, materiais ou criadores..."
                        style="border-radius: 20px 0 0 20px;">

                    <button class="btn btn-light border-0" type="button"
                        style="border-radius: 0 20px 20px 0;">
                        <i class="bi bi-search"></i>
                    </button>
                </div>
            </form>

            <div class="d-flex align-items-center">
                <a href="/upload" class="btn btn-outline-dark border-0 me-3 d-none d-sm-block">
                    <i class="bi bi-plus-square me-1"></i> Publicar Tutorial
                </a>

                <div class="dropdown">
                    <a href="#" class="d-block link-dark text-decoration-none dropdown-toggle"
                        id="dropdownUser" data-bs-toggle="dropdown" aria-expanded="false">

                        <img src="<%= user.profilePicture ? '/uploads/profiles/' + user.profilePicture : '/images/default-profile.png' %>"
                            alt="perfil" width="32" height="32" class="bg-secondary rounded-circle">
                    </a>

                    <ul class="dropdown-menu dropdown-menu-end text-small shadow border-0 mt-2"
                        aria-labelledby="dropdownUser">

                        <li>
                            <a class="dropdown-item py-2" href="/profile/edit">
                                <i class="bi bi-person me-2"></i> Meu Perfil
                            </a>
                        </li>

                        <li>
                            <a class="dropdown-item py-2" href="/my-videos">
                                <i class="bi bi-camera-video me-2"></i> Meus Tutoriais
                            </a>
                        </li>

                        <li>
                            <a class="dropdown-item py-2" href="/settings">
                                <i class="bi bi-gear me-2"></i> Configurações
                            </a>
                        </li>

                        <li>
                            <hr class="dropdown-divider">
                        </li>

                        <li>
                            <a class="dropdown-item py-2 text-danger" href="/logout">
                                <i class="bi bi-box-arrow-right me-2"></i> Sair
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </nav>

    <div class="container-fluid px-lg-5">
        <div class="row">

            <!-- Sidebar -->
            <aside class="col-md-3 col-lg-2 d-none d-md-block sidebar py-4">
                <nav class="nav flex-column">

                    <a class="nav-link active" href="/feed">
                        <i class="bi bi-house-door-fill me-2"></i> Início
                    </a>

                    <a class="nav-link" href="/following">
                        <i class="bi bi-people me-2"></i> Criadores Seguidos
                    </a>

                    <a class="nav-link" href="/explore">
                        <i class="bi bi-compass me-2"></i> Descobrir
                    </a>

                    <hr>

                    <p class="small text-muted px-3 mb-2">Minha Coleção</p>

                    <a class="nav-link py-2" href="/playlists">
                        <i class="bi bi-bookmark-heart me-2"></i> Favoritos
                    </a>

                    <a class="nav-link py-2" href="/liked">
                        <i class="bi bi-heart me-2"></i> Curtidos
                    </a>

                    <a class="nav-link py-2" href="#">
                        <i class="bi bi-palette me-2"></i> Artesanato
                    </a>

                    <a class="nav-link py-2" href="#">
                        <i class="bi bi-scissors me-2"></i> DIY
                    </a>
                </nav>
            </aside>

            <!-- Main Content -->
            <main class="col-12 col-md-9 col-lg-10 py-4">

                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div>
                        <h4 class="fw-bold mb-1">Tutoriais em Destaque</h4>
                        <p class="text-muted mb-0">
                            Descubra ideias criativas e aprenda algo novo hoje.
                        </p>
                    </div>

                    <div class="btn-group shadow-sm">
                        <button class="btn btn-white btn-sm active border">
                            Recentes
                        </button>

                        <button class="btn btn-white btn-sm border">
                            Em Alta
                        </button>
                    </div>
                </div>

                <div class="row g-4">

                    <!-- Tutorial Card 1 -->
                    <div class="col-6 col-md-4 col-lg-3">
                        <div class="video-card">

                            <div class="thumbnail-placeholder">
                                <i class="bi bi-play-circle play-icon"></i>

                                <span class="badge-views">
                                    <i class="bi bi-eye"></i> 1.8k
                                </span>
                            </div>

                            <div class="p-3">
                                <h6 class="text-truncate mb-1">
                                    Velas Artesanais com Flores
                                </h6>

                                <div class="d-flex align-items-center">
                                    <span class="text-muted small">
                                        @atelier_luna
                                    </span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Tutorial Card 2 -->
                    <div class="col-6 col-md-4 col-lg-3">
                        <div class="video-card">

                            <div class="thumbnail-placeholder">
                                <i class="bi bi-play-circle play-icon"></i>

                                <span class="badge-views">
                                    <i class="bi bi-eye"></i> 920
                                </span>
                            </div>

                            <div class="p-3">
                                <h6 class="text-truncate mb-1">
                                    Pintura em Garrafas de Vidro
                                </h6>

                                <span class="text-muted small">
                                    @craft_da_ana
                                </span>
                            </div>
                        </div>
                    </div>

                    <!-- Tutorial Card 3 -->
                    <div class="col-6 col-md-4 col-lg-3">
                        <div class="video-card">

                            <div class="thumbnail-placeholder">
                                <i class="bi bi-play-circle play-icon"></i>

                                <span class="badge-views">
                                    <i class="bi bi-eye"></i> 2.4k
                                </span>
                            </div>

                            <div class="p-3">
                                <h6 class="text-truncate mb-1">
                                    Decoração Minimalista DIY
                                </h6>

                                <span class="text-muted small">
                                    @studio.home
                                </span>
                            </div>
                        </div>
                    </div>

                    <!-- Tutorial Card 4 -->
                    <div class="col-6 col-md-4 col-lg-3">
                        <div class="video-card">

                            <div class="thumbnail-placeholder">
                                <i class="bi bi-play-circle play-icon"></i>

                                <span class="badge-views">
                                    <i class="bi bi-eye"></i> 3.7k
                                </span>
                            </div>

                            <div class="p-3">
                                <h6 class="text-truncate mb-1">
                                    Como Fazer Crochê para Iniciantes
                                </h6>

                                <span class="text-muted small">
                                    @fioemarte
                                </span>
                            </div>
                        </div>
                    </div>

                </div>

                <!-- Botão -->
                <div class="text-center mt-5">
                    <button class="btn btn-outline-primary px-5 rounded-pill fw-bold">
                        Carregar mais tutoriais
                    </button>
                </div>

            </main>
        </div>
    </div>

    <!-- Bootstrap 5 JS Bundle -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

</body>

</html>